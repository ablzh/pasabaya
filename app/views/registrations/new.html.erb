<div class="max-w-md mx-auto px-4 py-8">
  <h1 class="text-3xl font-extrabold text-neutral-900 dark:text-white mb-8 text-center">Create Your Account</h1>

  <%= render "shared/components/card/card", rounded: "3xl", padding: "lg" do %>
    <%= form_with model: @user, url: sign_up_path, class: "space-y-6" do |form| %>

      <% if @user.errors.any? %>
        <div class="bg-red-50 dark:bg-red-900/10 text-red-600 px-4 py-3 font-medium rounded-xl border border-red-100 dark:border-red-900/20">
          <ul class="list-disc ml-6 text-sm">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= form.label :first_name, "First Name", class: "block text-xs font-bold text-neutral-400 uppercase tracking-widest mb-2" %>
          <%= form.text_field :first_name, required: true, class: "w-full rounded-xl border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-sm focus:ring-blue-500 focus:border-blue-500" %>
        </div>

        <div>
          <%= form.label :last_name, "Last Name", class: "block text-xs font-bold text-neutral-400 uppercase tracking-widest mb-2" %>
          <%= form.text_field :last_name, required: true, class: "w-full rounded-xl border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-sm focus:ring-blue-500 focus:border-blue-500" %>
        </div>
      </div>

      <div>
        <%= form.label :facebook_profile_url, "Facebook Profile URL", class: "block text-xs font-bold text-neutral-400 uppercase tracking-widest mb-2" %>
        <%= form.url_field :facebook_profile_url, required: true, placeholder: "https://facebook.com/username", class: "w-full rounded-xl border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-sm focus:ring-blue-500 focus:border-blue-500" %>
        <p class="text-[10px] text-neutral-400 mt-1">Required for trust safety. Other users will view this link to verify you.</p>
      </div>

      <div>
        <%= form.label :email_address, "Email Address", class: "block text-xs font-bold text-neutral-400 uppercase tracking-widest mb-2" %>
        <%= form.email_field :email_address, required: true, class: "w-full rounded-xl border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= form.label :password, "Password", class: "block text-xs font-bold text-neutral-400 uppercase tracking-widest mb-2" %>
        <%= form.password_field :password, required: true, class: "w-full rounded-xl border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirm Password", class: "block text-xs font-bold text-neutral-400 uppercase tracking-widest mb-2" %>
        <%= form.password_field :password_confirmation, required: true, class: "w-full rounded-xl border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-sm focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div class="pt-4">
        <%= render "shared/components/buttons/button", text: "Create Account & Log In", type: "submit", size: "lg", full_width: true %>
      </div>
    <% end %>
  <% end %>
</div>
