<main class="bg-gray-50 min-h-screen flex flex-col items-center justify-center px-4 font-sans text-center">
  <div class="max-w-md w-full bg-white p-10 rounded-3xl shadow-xl border border-gray-100">
    <div class="text-6xl mb-6">👋</div>
    <h1 class="text-3xl font-extrabold text-gray-900 mb-4">You’re off the list</h1>
    <p class="text-lg text-gray-600 leading-relaxed mb-8">
      We’ve successfully removed you from our mailing list. You won’t receive any more updates from
      <span class="text-indigo-600 font-semibold">Pasabaya.app</span>.
    </p>

    <div class="pt-6 border-top border-gray-100">
      <p class="text-sm text-gray-400 mb-4">Changed your mind by mistake?</p>
      <%= link_to "Go back to Homepage", root_path,
                  class: "inline-block px-6 py-3 bg-indigo-600 text-white font-bold rounded-2xl hover:bg-indigo-700 transition-all shadow-md" %>
    </div>
  </div>

  <p class="mt-8 text-sm text-gray-400">
    Pasabaya.app — Commuting made social.
  </p>
</main>