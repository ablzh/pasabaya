<div class="max-w-4xl mx-auto px-4 py-8 space-y-12">

  <%# 1. Profile Header Card %>
  <%= render "shared/components/card/card", rounded: "3xl", padding: "lg" do %>
    <div class="flex flex-col sm:flex-row items-center gap-6 text-center sm:text-left">
      <%= user_avatar(@user, classes: "w-32 h-32 text-3xl shrink-0") %>
      <div class="flex-1 space-y-2">
        <h1 class="text-3xl font-extrabold text-neutral-900 dark:text-white tracking-tight">
          <%= @user.first_name %> <%= @user.last_name %>
        </h1>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">
          Member since <%= @user.created_at.strftime("%B %Y") %>
        </p>

        <%# Button Actions (Facebook Profile + Conditional Edit Profile) %>
        <div class="mt-4 flex flex-wrap gap-3 justify-center sm:justify-start">
          <% if @user.facebook_profile_url.present? %>
            <%= render "shared/components/buttons/button",
                       text: "View Facebook Profile",
                       href: @user.facebook_profile_url,
                       variant: "primary",
                       size: "sm",
                       target: "_blank" %>
          <% end %>

          <% if Current.user == @user %>
            <%= render "shared/components/buttons/button",
                       text: "Edit Profile",
                       href: edit_profile_path,
                       variant: "outline",
                       size: "sm" %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <%# 2. Listings Section %>
  <div>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-neutral-900 dark:text-white tracking-tight">Active Posts</h2>
      <span class="text-xs font-bold text-neutral-400 uppercase tracking-widest"><%= @ride_posts.count %> listings</span>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <% if @ride_posts.any? %>
        <%= render @ride_posts %>
      <% else %>
        <div class="col-span-full py-12 text-center text-neutral-500 bg-neutral-50 dark:bg-neutral-800/50 rounded-2xl border border-dashed border-neutral-200 dark:border-neutral-700">
          No active ride offers or requests listed at the moment.
        </div>
      <% end %>
    </div>
  </div>

</div>