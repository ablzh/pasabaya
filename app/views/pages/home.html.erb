<% set_meta_tags title: "Carpooling Philippines", reverse: false %>
<div class="flex flex-col items-center lg:px-8 font-sans">


  <div class="max-w-5xl w-full sm:px-6 lg:px-8">
    <%# 1. Hero Section %>
    <header class="text-center space-y-8 mb-16 mt-8">
      <span class="inline-block py-1.5 text-xs font-bold tracking-widest text-indigo-700 uppercase bg-indigo-100 dark:bg-indigo-900/30 dark:text-indigo-300 rounded-full">
        Community Ride Board
      </span>
      <h1 class="text-5xl font-extrabold text-neutral-900 dark:text-white tracking-tight sm:text-5xl md:text-7xl leading-tight">
        Carpooling for the Community, <br class="hidden lg:block">
        <span class="text-indigo-600 dark:text-indigo-400">Not for Profit.</span>
      </h1>
      <p class="max-w-2xl mx-auto text-xl text-neutral-600 dark:text-neutral-400 leading-relaxed">
        A smarter, social way to find travel companions in the Philippines. No fees. No commissions. Just people helping
        people beat the traffic.
      </p>

      <div class="max-w-4xl mx-auto pt-8">
        <%= render "ride_posts/search_form" %>
      </div>
    </header>

    <%# 2. The Problem %>
    <section class="max-w-3xl mx-auto mb-24">
      <%= render "shared/components/card/card", rounded: "3xl", padding: "lg" do %>
        <h2 class="text-3xl font-bold text-neutral-900 dark:text-white mb-6">Why Pasabaya.app?</h2>
        <div class="space-y-6 text-lg text-neutral-600 dark:text-neutral-400 leading-relaxed">
          <p>
            Traffic in the Philippines is a shared struggle. Public transport can be inconvenient for daily commutes of
            tens of kilometers, and while Facebook groups or Reddit threads help people find rides, they aren't built
            for it.
          </p>
          <p>With the recent declaration of an <strong>energy emergency</strong>, there is a clear need for us to be
            more efficient and travel together. Pasabaya.app is just an organized tool to help you find someone
            heading your way.</p>
          <p class="font-medium text-indigo-600 dark:text-indigo-400 text-xl border-l-4 border-indigo-200 dark:border-indigo-900/50 pl-6 mt-8">
            We took the "pasabay" culture you already know and gave it a better interface.
          </p>
        </div>
      <% end %>
    </section>

    <%# 3. How it Works %>
    <section class="mb-24">
      <h2 class="text-3xl font-bold text-neutral-900 dark:text-white mb-12 text-center max-w-2xl mx-auto">
        It’s Social Networking, <br class="hidden sm:block">
        Not a Transport Company.
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <%= render "shared/components/card/card", rounded: "3xl", padding: "lg", hoverable: true do %>
          <div class="w-14 h-14 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-2xl flex items-center justify-center mb-6 text-3xl">
            💸
          </div>
          <h3 class="text-xl font-bold text-neutral-900 dark:text-white mb-4">Zero Payments</h3>
          <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">
            We don't handle money. No booking fees, no commissions, no hidden costs.
          </p>
        <% end %>

        <%= render "shared/components/card/card", rounded: "3xl", padding: "lg", hoverable: true do %>
          <div class="w-14 h-14 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-2xl flex items-center justify-center mb-6 text-3xl">
            🛡️
          </div>
          <h3 class="text-xl font-bold text-neutral-900 dark:text-white mb-4">Facebook-Verified</h3>
          <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">
            Connect with real people. Check profiles and mutual friends before you decide to ride together.
          </p>
        <% end %>

        <%= render "shared/components/card/card", rounded: "3xl", padding: "lg", hoverable: true do %>
          <div class="w-14 h-14 bg-indigo-50 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-400 rounded-2xl flex items-center justify-center mb-6 text-3xl">
            🎯
          </div>
          <h3 class="text-xl font-bold text-neutral-900 dark:text-white mb-4">Simple Matching</h3>
          <p class="text-neutral-600 dark:text-neutral-400 leading-relaxed">
            No complex dispatching. Just a digital bulletin board with smart filters to find someone heading your way.
          </p>
        <% end %>
      </div>
    </section>

    <%# 4. About the Creator %>
    <section class="max-w-3xl mx-auto mb-24">
      <div class="bg-neutral-900 dark:bg-black rounded-3xl p-6 sm:p-14 shadow-2xl text-white relative overflow-hidden border border-white/5">
        <!-- Abstract shape decoration -->
        <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-indigo-600 opacity-20 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -ml-16 -mb-16 w-48 h-48 rounded-full bg-blue-500 opacity-20 blur-3xl"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-bold mb-8 text-indigo-300">From a Student, For the People</h2>
          <div class="space-y-6 text-lg text-neutral-300 leading-relaxed">
            <p>
              Hi, I’m <span class="text-white font-semibold">Artem Blazhievskii</span>, an MIS student at the University
              of the Philippines Open University.
            </p>
            <p>
              I’m building <span class="text-white font-semibold">Pasabaya.app</span> as an open-source volunteer
              project to help solve a problem we all face. I am not a transport company; I am just a developer who
              believes that technology should make our daily lives easier and more human.
            </p>
          </div>
        </div>
      </div>
    </section>

    <%# 5. Safety & Trust Section %>
    <section id="safety" class="max-w-4xl mx-auto mb-24">
      <div class="bg-amber-50 dark:bg-amber-950/20 rounded-3xl p-6 sm:p-14 border border-amber-100 dark:border-amber-900/30 shadow-sm">
        <div class="flex flex-col md:flex-row gap-10">
          <div class="flex-1">
            <h2 class="text-3xl font-bold text-neutral-900 dark:text-white mb-6 flex items-center gap-3">
              <span class="text-amber-600 dark:text-amber-400 text-4xl">🛡️</span> Safety First
            </h2>
            <div class="space-y-4 text-neutral-700 dark:text-neutral-300 leading-relaxed">
              <p>
                Pasabaya.app is a <strong>public bulletin board</strong>. We provide the tools to find matches, but the
                actual coordination happens between you and the other person on Facebook.
              </p>
              <p class="font-medium text-amber-800 dark:text-amber-200">
                You are responsible for your own safety. Always verify who you are traveling with.
              </p>
              <div class="pt-4 flex gap-3">
                <%= render "shared/components/buttons/button", 
                      text: "Safety & Terms", 
                      href: terms_path, 
                      variant: "outline", 
                      size: "sm" %>
                <%= render "shared/components/buttons/button", 
                      text: "Privacy", 
                      href: privacy_path, 
                      variant: "ghost", 
                      size: "sm" %>
              </div>
            </div>
          </div>
          <div class="flex-1 bg-white/50 dark:bg-neutral-800/50 rounded-2xl p-8 border border-amber-200/50 dark:border-amber-900/30">
            <h3 class="font-bold text-neutral-900 dark:text-white mb-4 uppercase tracking-wider text-sm">Trust Checklist</h3>
            <ul class="space-y-3">
              <li class="flex items-start gap-3">
                <span class="text-green-600 dark:text-green-400 font-bold">✓</span>
                <span class="text-sm text-neutral-700 dark:text-neutral-300">Check their Facebook profile age and activity.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-600 dark:text-green-400 font-bold">✓</span>
                <span class="text-sm text-neutral-700 dark:text-neutral-300">Look for mutual friends or common groups.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-600 dark:text-green-400 font-bold">✓</span>
                <span class="text-sm text-neutral-700 dark:text-neutral-300"><strong>Never pay in advance.</strong> Coordination is free.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-600 dark:text-green-400 font-bold">✓</span>
                <span class="text-sm text-neutral-700 dark:text-neutral-300">Share your location with family/friends during the ride.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-green-600 dark:text-green-400 font-bold">✓</span>
                <span class="text-sm text-neutral-700 dark:text-neutral-300">Meet in well-lit, public locations for pickup.</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <%# 6. Final Call to Action %>
    <section class="max-w-xl mx-auto text-center space-y-10 mb-16">
      <div class="space-y-4">
        <h3 class="text-3xl font-bold text-neutral-900 dark:text-white">Ready to find a ride?</h3>
        <p class="text-lg text-neutral-500 dark:text-neutral-400">Join the community and start saving on your commute today.</p>
      </div>
      <div class="flex justify-center">
        <%= render "shared/components/buttons/button", 
              text: "Browse All Rides", 
              href: ride_posts_path(post_type: "", origin_id: "", destination_id: ""),
              variant: "primary", 
              size: "lg", 
              style: "fancy",
              pill: true %>
      </div>
      <p class="text-sm text-neutral-400 dark:text-neutral-500 font-medium italic">
        * By using this site, you agree that Pasabaya.app is not liable for any incidents arising from external coordination.
      </p>
    </section>
  </div>
</div>
