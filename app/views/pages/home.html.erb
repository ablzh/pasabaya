<div class="bg-gray-50 min-h-screen flex flex-col items-center px-4 sm:px-6 lg:px-8 font-sans">
  <%# Displaying notifications %>
  <% if flash[:notice] %>
    <div class="fixed top-5 right-5 bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded shadow-lg animate-bounce z-50">
      <%= flash[:notice] %>
    </div>
  <% end %>
  <div class="max-w-5xl w-full py-16 px-4 sm:px-6 lg:px-8">
    <%# 1. Hero Section %>
    <div class="text-center space-y-8 mb-24 mt-8">
      <span class="inline-block px-4 py-1.5 text-xs font-bold tracking-widest text-indigo-700 uppercase bg-indigo-100 rounded-full">
        Coming Soon 2026
      </span>
      <h1 class="text-5xl font-extrabold text-gray-900 tracking-tight sm:text-6xl md:text-7xl leading-tight">
        Carpooling for the Community, <br class="hidden lg:block">
        <span class="text-indigo-600">Not for Profit.</span>
      </h1>
      <p class="max-w-2xl mx-auto text-xl text-gray-600 leading-relaxed">
        A smarter, social way to find travel companions in the Philippines. No fees. No commissions. Just people helping
        people beat the traffic.
      </p>
    </div>
    <%# 2. The Problem %>
    <div class="max-w-3xl mx-auto mb-24">
      <div class="bg-white rounded-3xl p-10 sm:p-14 shadow-sm border border-gray-100">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">Why Pasabaya.app?</h2>
        <div class="space-y-6 text-lg text-gray-600 leading-relaxed">
          <p>
            Traffic in the Philippines is a shared struggle. Public transport can be inconvenient for daily commutes of
            tens of kilometers, and while Facebook groups or Reddit threads help people find rides, they aren't built
            for it.
          </p>
          <p>With the recent declaration of an <strong>energy emergency</strong>, there is a clear need for us to be
            more efficient and travel together. Pasabaya.app is just an organized tool to help you find someone
            heading your way.</p>
          <p class="font-medium text-indigo-600 text-xl border-l-4 border-indigo-200 pl-6 mt-8">
            We took the "pasabay" culture you already know and gave it a better interface.
          </p>
        </div>
      </div>
    </div>
    <%# 3. How it Works %>
    <div class="mb-24">
      <h2 class="text-3xl font-bold text-gray-900 mb-12 text-center max-w-2xl mx-auto">
        It’s Social Networking, <br class="hidden sm:block">
        Not a Transport Company.
      </h2>
      <div class="grid gap-8 md:grid-cols-3">
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 transition-all hover:shadow-md">
          <div class="w-14 h-14 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-6 text-3xl">
            💸
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Zero Payments</h3>
          <p class="text-gray-600 leading-relaxed">
            We don't handle money. No booking fees, no commissions, no hidden costs.
          </p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 transition-all hover:shadow-md">
          <div class="w-14 h-14 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-6 text-3xl">
            🛡️
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Facebook-Verified</h3>
          <p class="text-gray-600 leading-relaxed">
            Connect with real people. Check profiles and mutual friends before you decide to ride together.
          </p>
        </div>
        <div class="bg-white p-8 rounded-3xl shadow-sm border border-gray-100 transition-all hover:shadow-md">
          <div class="w-14 h-14 bg-indigo-50 text-indigo-600 rounded-2xl flex items-center justify-center mb-6 text-3xl">
            🎯
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-4">Simple Matching</h3>
          <p class="text-gray-600 leading-relaxed">
            No complex dispatching. Just a digital bulletin board with smart filters to find someone heading your way.
          </p>
        </div>
      </div>
    </div>
    <%# 4. About the Creator %>
    <div class="max-w-3xl mx-auto mb-24">
      <div class="bg-gray-900 rounded-3xl p-10 sm:p-14 shadow-2xl text-white relative overflow-hidden">
        <!-- Abstract shape decoration -->
        <div class="absolute top-0 right-0 -mr-16 -mt-16 w-64 h-64 rounded-full bg-indigo-600 opacity-20 blur-3xl"></div>
        <div class="absolute bottom-0 left-0 -ml-16 -mb-16 w-48 h-48 rounded-full bg-blue-500 opacity-20 blur-3xl"></div>
        <div class="relative z-10">
          <h2 class="text-3xl font-bold mb-8 text-indigo-300">From a Student, For the People</h2>
          <div class="space-y-6 text-lg text-gray-300 leading-relaxed">
            <p>
              Hi, I’m <span class="text-white font-semibold">Artem Blazhievskii</span>, an MIS student at the University
              of the Philippines Open University.
            </p>
            <p>
              I’m building <span class="text-white font-semibold">Pasabaya.app</span> as an open-source volunteer
              project to help solve a problem we all face. I am not a transport company; I am just a developer who
              believes that technology should make our daily lives easier and more human.
            </p>
          </div>
        </div>
      </div>
    </div>
    <%# 5. Call to Action (Form) %>
    <div id="waitlist" class="max-w-xl mx-auto text-center space-y-10 mb-16">
      <div class="space-y-4">
        <h3 class="text-3xl font-bold text-gray-900">Join the Waitlist</h3>
        <p class="text-lg text-gray-500">Get notified when we launch. No spam, ever.</p>
      </div>
      <div class="bg-white py-10 px-6 sm:px-12 shadow-2xl rounded-3xl border border-gray-100">
        <% if flash[:notice] %>
          <div class="text-indigo-600 font-bold py-4 text-xl animate-pulse">
            ✨ You're on the list!
          </div>
          <p class="text-gray-500 mt-2">Check your inbox for a confirmation email.</p>
        <% else %>
          <%= form_with model: (@subscriber || Subscriber.new), class: "space-y-6" do |f| %>
            <% if @subscriber && @subscriber.errors.any? %>
              <div class="text-red-500 text-sm text-left bg-red-50 p-4 rounded-xl">
                <%= @subscriber.errors.full_messages.first %>
              </div>
            <% end %>
            <div class="space-y-2">
              <%= f.text_field :name,
                               placeholder: "Your Name",
                               class: "appearance-none block w-full px-5 py-4 border border-gray-200 rounded-2xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all sm:text-base bg-gray-50 focus:bg-white" %>
            </div>
            <div class="space-y-2">
              <%= f.email_field :email,
                                placeholder: "Email address",
                                class: "appearance-none block w-full px-5 py-4 border border-gray-200 rounded-2xl shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all sm:text-base bg-gray-50 focus:bg-white" %>
            </div>
            <div class="flex items-start pt-2 text-left">
              <div class="flex items-center h-6">
                <%= f.check_box :terms_accepted,
                                required: true,
                                class: "w-5 h-5 text-indigo-600 border-gray-300 rounded focus:ring-indigo-500 cursor-pointer mt-0.5" %>
              </div>
              <div class="ml-3 text-sm">
                <label for="subscriber_terms_accepted" class="text-gray-500 leading-snug cursor-pointer block">
                  I agree to the processing of my data according to the
                  <a href="/privacy" class="text-indigo-600 hover:underline font-semibold">Privacy Policy</a>
                  and Philippine DPA of 2012.
                </label>
              </div>
            </div>
            <div class="pt-4">
              <%= f.submit "Join the Future of Commuting",
                           class: "w-full flex justify-center py-4 px-6 border border-transparent rounded-2xl shadow-lg text-lg font-bold text-white bg-indigo-600 hover:bg-indigo-700 hover:scale-[1.02] active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all cursor-pointer" %>
            </div>
          <% end %>
        <% end %>
      </div>
      <p class="text-sm text-gray-400 font-medium">
        🚀 Launching soon in Metro Manila and beyond.
      </p>
    </div>
  </div>
</div>
