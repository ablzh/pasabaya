<div class="max-w-2xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-extrabold text-neutral-900 dark:text-white mb-8">Edit Profile</h1>

  <%= render "shared/components/card/card", rounded: "3xl", padding: "lg" do %>
    <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-6" do |form| %>

      <% if @user.errors.any? %>
        <div class="bg-red-50 dark:bg-red-900/10 text-red-600 px-4 py-3 font-medium rounded-xl border border-red-100 dark:border-red-900/20">
          <ul class="list-disc ml-6 text-sm">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex items-center gap-6">
        <%= user_avatar(@user, classes: "w-20 h-20 text-2xl") %>
        <div class="flex-1">
          <%= render "shared/components/forms/form_group",
            label: "Upload Avatar",
            name: :avatar,
            error: @user.errors[:avatar].first do %>
            <%= form.file_field :avatar, class: "block w-full text-sm text-neutral-500 file:mr-4 file:py-2.5 file:px-4 file:rounded-xl file:border file:border-neutral-200 dark:file:border-neutral-700 file:text-sm file:font-semibold file:bg-neutral-50 dark:file:bg-neutral-800 file:text-neutral-700 dark:file:text-neutral-300 hover:file:bg-neutral-100 dark:hover:file:bg-neutral-700 cursor-pointer" %>
          <% end %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <%= render "shared/components/forms/form_group",
          label: "First Name",
          name: :first_name,
          error: @user.errors[:first_name].first do %>
          <%= form.text_field :first_name, class: "w-full rounded-xl border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-sm focus:ring-blue-500 focus:border-blue-500 py-3 px-4" %>
        <% end %>

        <%= render "shared/components/forms/form_group",
          label: "Last Name",
          name: :last_name,
          error: @user.errors[:last_name].first do %>
          <%= form.text_field :last_name, class: "w-full rounded-xl border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-sm focus:ring-blue-500 focus:border-blue-500 py-3 px-4" %>
        <% end %>
      </div>

      <%= render "shared/components/forms/form_group",
        label: "Facebook Profile URL",
        name: :facebook_profile_url,
        helper_text: "Required. Other members will use this to view your profile and contact you.",
        error: @user.errors[:facebook_profile_url].first do %>
        <%= form.url_field :facebook_profile_url, placeholder: "https://facebook.com/username", class: "w-full rounded-xl border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-800 text-sm focus:ring-blue-500 focus:border-blue-500 py-3 px-4" %>
      <% end %>

      <div class="pt-6 border-t border-neutral-100 dark:border-white/5">
        <%= render "shared/components/buttons/button", text: "Save Profile Changes", type: "submit", size: "lg" %>
      </div>
    <% end %>
  <% end %>
</div>