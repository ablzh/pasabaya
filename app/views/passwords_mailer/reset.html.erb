<!DOCTYPE html>
<html>
  <head>
    <meta content='text/html; charset=UTF-8' http-equiv='Content-Type' />
    <style>
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        color: #262626;
        line-height: 1.6;
        background-color: #fafafa;
        margin: 0;
        padding: 0;
      }
      .wrapper {
        width: 100%;
        background-color: #fafafa;
        padding: 24px 0;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        background-color: #ffffff;
        border: 1px solid #e5e5e5;
        border-radius: 12px;
        overflow: hidden;
      }
      .header {
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        padding: 32px 24px;
        text-align: center;
      }
      .header h1 {
        color: #ffffff;
        margin: 0;
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -0.5px;
      }
      .content {
        padding: 32px 24px;
      }
      .title {
        font-size: 20px;
        font-weight: 600;
        margin-top: 0;
        margin-bottom: 16px;
      }
      .intro {
        font-size: 16px;
        color: #4b5563;
        margin-bottom: 24px;
      }
      .btn-link {
        display: inline-block;
        background-color: #4f46e5;
        color: #ffffff !important;
        padding: 12px 24px;
        font-weight: 600;
        text-decoration: none;
        border-radius: 8px;
        margin-bottom: 28px;
      }
      .card {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 20px;
      }
      .card-title {
        font-weight: 600;
        margin-top: 0;
        margin-bottom: 8px;
        color: #1e293b;
        font-size: 15px;
      }
      .card-text {
        margin: 0;
        font-size: 14px;
        color: #4b5563;
      }
      .footer {
        padding: 24px;
        text-align: center;
        font-size: 12px;
        color: #9ca3af;
        border-top: 1px solid #f3f4f6;
      }
      .footer a {
        color: #6366f1;
        text-decoration: none;
      }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="container">
        <!-- Brand Header -->
        <div class="header">
          <h1>Pasabaya.app 🚗</h1>
        </div>

        <!-- Main Body Content -->
        <div class="content">
          <p class="title">Password Reset Request</p>
          
          <p class="intro">
            You are receiving this email because a request was made to reset the password for your Pasabaya account.
          </p>

          <!-- Reset Button -->
          <div style="text-align: left;">
            <%= link_to "Reset Password ➔", edit_password_url(@user.password_reset_token), class: "btn-link" %>
          </div>

          <!-- Expiration Notice -->
          <div class="card">
            <h3 class="card-title">⏳ Expiration Notice</h3>
            <p class="card-text">
              For security reasons, this password reset link will expire in <%= distance_of_time_in_words(0, @user.password_reset_token_expires_in) %>. After that, you will need to request a new link.
            </p>
          </div>

          <!-- Security Note -->
          <div class="card" style="border-left: 4px solid #ef4444; background-color: #fef2f2; margin-bottom: 0;">
            <h3 class="card-title" style="color: #991b1b;">🛡️ Didn't Request This?</h3>
            <p class="card-text" style="color: #7f1d1d;">
              If you didn't request a password reset, you can safely ignore this email. Your password will remain unchanged and your account secure.
            </p>
          </div>
        </div>

        <!-- Footer -->
        <div class="footer">
          <p>&copy; <%= Time.current.year %> Pasabaya.app. All rights reserved.</p>
          <p>
            You received this email because you registered on <a href="https://pasabaya.app">pasabaya.app</a>. If you have questions, message me on Facebook: <a href="https://www.facebook.com/people/Pasabayaapp-Carpooling-for-the-Community/61589209230043/">Pasabaya page</a>.
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
