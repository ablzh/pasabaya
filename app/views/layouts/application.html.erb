<!DOCTYPE html>
<html class="dark">
<head>

  <%= display_meta_tags site: 'Pasabaya',
                        title: 'Carpooling Philippines',
                        reverse: true,
                        separator: '|',
                        description: 'A smarter, social way to find travel companions in the Philippines. No fees. No commissions. Just people helping people beat the traffic.',
                        keywords: 'carpooling, Philippines, ride sharing, pasabaya, pasabay',
                        og: {
                          site_name: 'Pasabaya',
                          title: :title,
                          description: :description,
                          type: 'website',
                          url: request.original_url,
                          image: image_url('og-preview.png')
                        } %>

  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="application-name" content="Pasabaya - Carpooling Philippines">
  <meta name="mobile-web-app-capable" content="yes">

  <%= turbo_refreshes_with method: :morph, scroll: :preserve %>

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
  <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

  <link rel="icon" href="/icon.png" type="image/png">
  <link rel="icon" href="/icon.svg" type="image/svg+xml">
  <link rel="apple-touch-icon" href="/icon.png">

  <!-- Shoelace -->
  <script type="module" src="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.20.1/cdn/components/color-picker/color-picker.js"></script>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.20.1/cdn/themes/light.css"
    />
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.20.1/cdn/themes/dark.css"
    />

  <!-- Tom Select -->
  <link href="https://cdn.jsdelivr.net/npm/tom-select@2.5.2/dist/css/tom-select.css" rel="stylesheet">

  <!-- Air Datepicker -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/air-datepicker@3.6.0/air-datepicker.min.css">

  <!-- Photoswipe -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe/dist/photoswipe.css">

  <%# Includes all stylesheet files in app/assets/stylesheets %>
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>

  <% if Rails.env.production? %>
    <!-- Umami -->
    <script defer src="https://cloud.umami.is/script.js" data-website-id="58f06de2-cb25-468e-af55-ab4838a7f4f1"></script>
  <% end %>
</head>

<body class="dark:bg-neutral-900 text-neutral-100 flex flex-col min-h-screen">

<%= render "shared/components/navbar/navbar" %>

<%# Global Flash Container %>
<div id="flash-notifications" class="fixed top-5 right-5 z-50 space-y-3">
  <% flash.each do |type, message| %>
    <% 
      # Dynamic colors based on flash type
      theme_classes = if type == "alert"
        "bg-red-100 border-red-400 text-red-700 dark:bg-red-950/20 dark:border-red-900/30 dark:text-red-400"
      else
        "bg-green-100 border-green-400 text-green-700 dark:bg-green-950/20 dark:border-green-900/30 dark:text-green-400"
      end
    %>
    <div data-turbo-temporary
         data-controller="flash"
         data-action="click->flash#dismiss"
         class="<%= theme_classes %> border px-4 py-3 rounded-xl shadow-lg animate-bounce">
      <%= message %>
    </div>
  <% end %>
</div>

<main class="container mx-auto px-4 mt-8 flex-grow">
  <%= yield %>
</main>

<%# Global Footer %>
<footer class="mt-auto py-12 border-t border-neutral-200 dark:border-neutral-800">
  <div class="container mx-auto px-4">
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <div class="text-center md:text-left">

        <div class="flex items-center gap-2 justify-center md:justify-start">
          <%= image_tag "logo.svg", class: "h-5 w-5 opacity-70 hover:opacity-100 transition-opacity", alt: "Pasabaya Logo" %>
          <p class="text-sm font-bold text-neutral-900 dark:text-white">Pasabaya.app</p>
        </div>

        <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-1">
          &copy; <%= Time.current.year %> All rights reserved.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-6">
        <a href="https://www.facebook.com/people/Pasabayaapp-Carpooling-for-the-Community/61589209230043/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-xs text-neutral-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
          <svg class="size-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          Support & Feedback
        </a>
        <a href="https://github.com/ablzh/pasabaya" target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-xs text-neutral-500 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
          <svg class="size-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          Contribute on GitHub
        </a>
      </div>

      <div class="flex gap-4">
        <%= link_to "Privacy", privacy_path, class: "text-xs text-neutral-400 hover:text-indigo-600 dark:hover:text-indigo-400" %>
        <%= link_to "Terms", terms_path, class: "text-xs text-neutral-400 hover:text-indigo-600 dark:hover:text-indigo-400" %>
      </div>
    </div>
  </div>
</footer>
</body>
</html>
