<%= form_with(model: ride_post, class: "w-full max-w-sm space-y-6") do |form| %>
  <% if ride_post.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3 mb-6">
      <h2><%= pluralize(ride_post.errors.count, "error") %> prohibited this post from being saved:</h2>
      <ul class="list-disc ml-6">
        <% ride_post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Post Type (Enum) -->
  <div class="mb-6 relative gap-y-1.5">
    <%= form.label :post_type, "Are you offering or requesting a ride?", class: "block font-medium mb-1" %>
    <%= form.select :post_type, RidePost.post_types.keys.map { |pt| [pt.titleize, pt] }, {}, class: "form-control" %>
  </div>

  <!-- Origin Location -->
  <div class="mb-6 relative gap-y-1.5">
    <%= form.label :origin_id, "Leaving from (City)", class: "block font-medium mb-1" %>
    <%= form.collection_select :origin_id, Location.city, :id, :name, { prompt: "Select a city..." }, { class: "form-control" } %>
  </div>

  <!-- Destination Location -->
  <div class="mb-6 relative gap-y-1.5">
    <%= form.label :destination_id, "Going to (City)", class: "block font-medium mb-1" %>
    <%= form.collection_select :destination_id, Location.city, :id, :name, { prompt: "Select a city..." }, { class: "form-control" } %>
  </div>

  <!-- Departure Time -->
  <div class="mb-6 relative gap-y-1.5">
    <%= form.label :departure_time, "Departure Time", class: "block font-medium mb-1" %>
    <%= form.datetime_field :departure_time,
                            class: "form-control",
                            min: Time.current.strftime("%Y-%m-%dT%H:%M")%>
  </div>

  <!-- Seats Available/Needed -->
  <div class="mb-6 relative gap-y-1.5">
    <%= form.label :seats, "Seats", class: "block font-medium mb-1" %>
    <%= form.number_field :seats, min: 1, class: "form-control" %>
  </div>

  <!-- Notes -->
  <div class="mb-6 relative gap-y-1.5">
    <%= form.label :notes, "Details (Optional)", class: "block font-medium mb-1" %>
    <%= form.text_area :notes, rows: 4, class: "form-control", placeholder: "e.g., Willing to split gas, I have a small dog, etc." %>
  </div>

  <!-- Submit Button -->
  <div class="inline">
    <%= form.submit "Post Ride", class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
    <%= render "shared/components/buttons/button",
               text: "Post Ride",
               type: "submit" %>
  </div>

<% end %>
